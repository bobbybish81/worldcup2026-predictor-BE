generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique
  password            String
  isAdmin             Boolean              @default(false)
  predictions         Prediction[]
  knockoutPredictions KnockoutPrediction[]
  points              Points?
}

model Team {
  id    Int    @id @default(autoincrement())
  name  String
  group String

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")

  knockoutHomeMatches KnockoutPrediction[] @relation("HomeTeamKO")
  knockoutAwayMatches KnockoutPrediction[] @relation("AwayTeamKO")
  knockoutWins        KnockoutPrediction[] @relation("WinnerTeamKO")
}

model Match {
  id         Int      @id @default(autoincrement())
  homeTeamId Int
  awayTeamId Int
  stage      String
  kickoff    DateTime
  homeScore  Int?
  awayScore  Int?

  homeTeam   Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  predictions Prediction[]
}


model Points {
  id            Int @id @default(autoincrement())
  userId        Int @unique
  groupStage    Int @default(0)
  knockoutStage Int @default(0)
  total         Int @default(0)

  user User @relation(fields: [userId], references: [id])
}

model Prediction {
  id        Int @id @default(autoincrement())
  userId    Int
  matchId   Int
  homeScore Int
  awayScore Int

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

model KnockoutPrediction {
  id                 Int    @id @default(autoincrement())
  userId             Int
  round              String
  matchKey           String
  homeTeamId         Int
  awayTeamId         Int
  winnerTeamId       Int?
  actualWinnerTeamId Int?

  user       User  @relation(fields: [userId], references: [id])
  homeTeam   Team  @relation("HomeTeamKO", fields: [homeTeamId], references: [id])
  awayTeam   Team  @relation("AwayTeamKO", fields: [awayTeamId], references: [id])
  winnerTeam Team? @relation("WinnerTeamKO", fields: [winnerTeamId], references: [id])

  @@unique([userId, matchKey])
}
